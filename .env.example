# 环境变量配置示例
# 复制为 .env 并修改: cp .env.example .env

# ==================================
# 服务器配置
# ==================================
TTS_HOST=0.0.0.0
TTS_PORT=8880

# API Key（客户端需在 Authorization: Bearer <key> 头中携带）
TTS_API_KEY=sk-local-qwen3-tts

# ==================================
# 模型配置
# ==================================
# 0.6B 模型: 适合 12GB 显存（RTX 3060）
TTS_BASE_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-Base
# 1.7B 模型: 需要 24GB+ 显存（RTX 3090/4090），效果更好
# TTS_BASE_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base

# 推理设备（单卡用 cuda:0，多卡可改 cuda:1 等）
TTS_DEVICE=cuda:0

# ==================================
# 推理加速配置
# ==================================

# torch.compile 加速（20-40% 提速，但启动多花 30-60s 编译）
# 建议先设 false 验证功能正常，再改为 true
TTS_TORCH_COMPILE=false

# 启动时预热（消除首次请求冷启动延迟，需已有注册音色）
TTS_WARMUP=true

# ==================================
# 国内模型下载加速（可选）
# ==================================
# HF_ENDPOINT=https://hf-mirror.com
